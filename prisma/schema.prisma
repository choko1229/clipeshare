generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  OWNER
}

enum PostType {
  CLIP
  SCREENSHOT
}

enum PostStatus {
  PROCESSING
  PUBLISHED
  PRIVATE
  HIDDEN
  FAILED
  DELETED
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum ReportTargetType {
  POST
  COMMENT
  USER
}

enum ReportStatus {
  OPEN
  REVIEWING
  ACTION_TAKEN
  REJECTED
  CLOSED
}

enum UploadJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id              String    @id @default(cuid())
  username        String?   @unique
  displayName     String?
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?   @db.Text
  avatarUrl       String?   @db.Text
  bio             String?   @db.Text
  role            UserRole  @default(USER)
  accountLevelId  String?
  isBanned        Boolean   @default(false)
  banReason       String?   @db.Text
  bannedAt        DateTime?
  ageVerifiedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  posts           Post[]
  comments        Comment[]
  likes           Like[]
  bookmarks       Bookmark[]
  links           UserLink[]
  reports         Report[]  @relation("Reporter")
  handledReports  Report[]  @relation("ReportHandler")
  auditLogs       AdminAuditLog[]
  accountLevel    AccountLevel? @relation(fields: [accountLevelId], references: [id])

  following       Follow[] @relation("Follower")
  followers       Follow[] @relation("Following")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model AccountLevel {
  id                 String   @id @default(cuid())
  name               String   @unique
  maxVideoSeconds    Int
  maxVideoSizeBytes  BigInt
  maxImageSizeBytes  BigInt
  dailyUploadLimit   Int?
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users User[]
}

model UserLink {
  id        String   @id @default(cuid())
  userId    String
  type      String
  label     String?
  url       String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  aliases      Json?
  summary      String?   @db.Text
  coverUrl     String?   @db.Text
  heroUrl      String?   @db.Text
  officialUrl  String?   @db.Text
  igdbId       Int?      @unique
  steamAppId   Int?      @unique
  rawgSlug     String?
  genres       Json?
  platforms    Json?
  releaseDate  DateTime?
  lastSyncedAt DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  posts Post[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  posts PostTag[]
}

model Post {
  id                  String     @id @default(cuid())
  publicId            String     @unique
  userId              String
  gameId              String
  type                PostType
  title               String
  description         String     @db.Text
  status              PostStatus @default(PROCESSING)
  visibility          Visibility @default(PUBLIC)
  thumbnailUrl        String     @db.Text
  mediaUrl            String?    @db.Text
  originalFilePath    String?    @db.Text
  hlsPath             String?    @db.Text
  durationSeconds     Int?
  fileSizeBytes       BigInt?
  width               Int?
  height              Int?
  rankName            String?
  discordServerName   String?
  customFields        Json?
  isNsfw              Boolean    @default(false)
  nsfwSetByAdminId    String?
  viewCount           BigInt     @default(0)
  likeCount           BigInt     @default(0)
  commentCount        BigInt     @default(0)
  bookmarkCount       BigInt     @default(0)
  publishedAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  game       Game        @relation(fields: [gameId], references: [id])
  tags       PostTag[]
  comments   Comment[]
  likes      Like[]
  bookmarks  Bookmark[]
  uploadJobs UploadJob[]

  @@index([status, visibility, publishedAt])
  @@index([gameId, publishedAt])
  @@index([userId, publishedAt])
  @@index([type, publishedAt])
  @@index([isNsfw, publishedAt])
}

model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Comment {
  id               String     @id @default(cuid())
  postId           String
  userId           String
  body             String     @db.Text
  status           PostStatus @default(PUBLISHED)
  deletedByAdminId String?
  createdAt        DateTime   @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Bookmark {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Report {
  id               String           @id @default(cuid())
  reporterId       String
  targetType       ReportTargetType
  targetId         String
  reason           String
  detail           String?          @db.Text
  status           ReportStatus     @default(OPEN)
  handledByAdminId String?
  handledAt        DateTime?
  createdAt        DateTime         @default(now())

  reporter User  @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  handler  User? @relation("ReportHandler", fields: [handledByAdminId], references: [id])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String
  targetType  String
  targetId    String
  beforeData  Json?
  afterData   Json?
  reason      String?  @db.Text
  ipAddress   String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])
}

model UploadJob {
  id           String          @id @default(cuid())
  postId       String
  status       UploadJobStatus @default(QUEUED)
  inputPath    String          @db.Text
  outputPath   String?         @db.Text
  errorMessage String?         @db.Text
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime        @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model ModerationRule {
  id        String   @id @default(cuid())
  type      String
  pattern   String
  action    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model StorageSetting {
  id               String   @id @default(cuid())
  key              String   @unique
  value            String
  description      String?  @db.Text
  updatedByAdminId String?
  updatedAt        DateTime @updatedAt
}
